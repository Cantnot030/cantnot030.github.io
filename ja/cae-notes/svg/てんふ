<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 500">

  <!-- 背景 -->
  <rect width="100%" height="100%" fill="white"/>

  <!-- ===== 車（簡略） ===== -->
  <g stroke="black" stroke-width="3" fill="none">
    <!-- ボディ -->
    <path d="M80 260 L120 200 L200 180 L280 200 L320 260 L300 300 L100 300 Z"/>
    <!-- タイヤ -->
    <circle cx="140" cy="310" r="20"/>
    <circle cx="260" cy="310" r="20"/>
  </g>

  <!-- ===== 拡大矢印 ===== -->
  <line x1="320" y1="250" x2="430" y2="200"
        stroke="black" stroke-width="3" marker-end="url(#arrow)"/>

  <!-- 矢印定義 -->
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="10" refX="8" refY="3"
            orient="auto">
      <polygon points="0 0, 10 3, 0 6" fill="black"/>
    </marker>
  </defs>

  <!-- ===== メッシュ領域 ===== -->
  <rect x="450" y="120" width="180" height="180"
        fill="none" stroke="black" stroke-width="3"/>

  <!-- メッシュ線 -->
  <g stroke="black" stroke-width="1">
    <!-- 縦 -->
    <line x1="480" y1="120" x2="480" y2="300"/>
    <line x1="510" y1="120" x2="510" y2="300"/>
    <line x1="540" y1="120" x2="540" y2="300"/>
    <line x1="570" y1="120" x2="570" y2="300"/>
    <line x1="600" y1="120" x2="600" y2="300"/>

    <!-- 横 -->
    <line x1="450" y1="150" x2="630" y2="150"/>
    <line x1="450" y1="180" x2="630" y2="180"/>
    <line x1="450" y1="210" x2="630" y2="210"/>
    <line x1="450" y1="240" x2="630" y2="240"/>
    <line x1="450" y1="270" x2="630" y2="270"/>
  </g>

  <!-- ===== 要素を1つ強調 ===== -->
  <rect x="510" y="180" width="30" height="30"
        fill="rgba(255,0,0,0.2)" stroke="red" stroke-width="2"/>

  <!-- 矢印（要素へ） -->
  <line x1="540" y1="300" x2="700" y2="320"
        stroke="black" stroke-width="3" marker-end="url(#arrow)"/>

  <!-- ===== 要素拡大図 ===== -->
  <rect x="720" y="280" width="120" height="120"
        fill="none" stroke="black" stroke-width="3"/>

  <!-- 節点（ノード） -->
  <circle cx="720" cy="280" r="5" fill="red"/>
  <circle cx="840" cy="280" r="5" fill="red"/>
  <circle cx="720" cy="400" r="5" fill="red"/>
  <circle cx="840" cy="400" r="5" fill="red"/>

  <!-- 節点ラベル -->
  <text x="710" y="270" font-size="14">Node</text>

  <!-- 要素ラベル -->
  <text x="740" y="420" font-size="14">Element</text>

</svg>